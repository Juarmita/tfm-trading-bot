# =========================================================================
# CONFIGURACIÓN GENERAL DEL REPOSITORIO TFM - VARIABLES DE ENTORNO
# =========================================================================

# -------------------------------------------------------------------------
# 1. SUPABASE (Configuración del Cliente y Servidor)
# -------------------------------------------------------------------------
# URL pública de tu API de Supabase (ej: https://abcde.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto-ref.supabase.co

# Clave pública de acceso anónimo de Supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-clave-anonima-publica

# Clave privada Service Role (¡NUNCA expongas esto al cliente!)
# Utilizada únicamente por el backend o servicios administrados
SUPABASE_SERVICE_ROLE_KEY=tu-clave-privada-service-role

# -------------------------------------------------------------------------
# 2. FASTAPI (Servicio de Backend)
# -------------------------------------------------------------------------
# URL donde corre el servidor de FastAPI (ej: http://localhost:8000 en dev)
FASTAPI_BASE_URL=http://localhost:8000

# Conexión a la base de datos PostgreSQL directa de Supabase
DATABASE_URL=postgresql://postgres.tu-ref:contraseña@aws-0-eu-west-3.pooler.supabase.com:5432/postgres

# -------------------------------------------------------------------------
# 3. SEGURIDAD Y SECRETS (Tokens y Criptografía)
# -------------------------------------------------------------------------
# Secreto para firmar y verificar tokens JWT de Supabase en el backend.
# ¡Obtenido del panel de control de Supabase -> Settings -> API -> JWT Secret!
SUPABASE_JWT_SECRET=tu-secreto-jwt-de-supabase-obtenido-del-panel

# Orígenes CORS permitidos (separados por comas. Ej: https://tudominio.com,http://localhost:3000)
CORS_ORIGINS=http://localhost:3000,https://frontend-five-kohl-4rc8ugx0s0.vercel.app

# Clave secreta para cookies de sesión del frontend (ej: NextAuth)
SESSION_SECRET=tu-secreto-sesion-cookie-nextjs

# -------------------------------------------------------------------------
# 4. REDIS (Caching e Integración Asíncrona - Opcional)
# -------------------------------------------------------------------------
# URL de conexión del servidor Redis (ej: redis://localhost:6379/0)
REDIS_URL=redis://localhost:6379/0

# -------------------------------------------------------------------------
# 5. YAHOO FINANCE (Integraciones opcionales)
# -------------------------------------------------------------------------
# Clave API opcional si utilizas servicios Yahoo Finance de pago / RapidAPI
YAHOO_FINANCE_API_KEY=tu-api-key-opcional
